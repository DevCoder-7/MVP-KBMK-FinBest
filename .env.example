# Neon PostgreSQL
# Use the pooled host (-pooler) for the application runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Use the direct host (without -pooler) for Prisma schema operations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Required for production login cookies.
SESSION_SECRET="replace-with-a-long-random-secret"

# Optional market data provider. Default is Yahoo Finance chart endpoint without key.
MARKET_DATA_PROVIDER="yahoo"
MARKET_CACHE_TTL_MS="30000"
MARKET_FETCH_TIMEOUT_MS="4000"

# Optional official/free-tier provider with API key.
# MARKET_DATA_PROVIDER="twelvedata"
# TWELVE_DATA_API_KEY="your_twelve_data_key"
